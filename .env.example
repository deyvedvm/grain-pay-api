# Database
POSTGRES_DATASOURCE_URL=jdbc:postgresql://localhost:5432/grainpay
POSTGRES_DATASOURCE_USERNAME=postgres
POSTGRES_DATASOURCE_PASSWORD=postgres

# Server
PORT=8080

# JWT
# Generate with: openssl rand -base64 32
JWT_SECRET=your-base64-secret-here
JWT_EXPIRATION=86400000

# CORS (comma-separated list of allowed origins)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Email (SMTP)
# Dev: use Mailtrap (https://mailtrap.io)
#
# Para habilitar envio de e-mail real (alertas de orçamento) em dev:
#   1. Crie conta gratuita em https://mailtrap.io
#   2. Sandbox → Inboxes → My Inbox → Integrations → SMTP Settings
#   3. Copie Username/Password para MAIL_USERNAME e MAIL_PASSWORD abaixo
#   4. Reabilite o health check: remova ou troque para `true` o bloco
#      `management.health.mail.enabled` em src/main/resources/application-local.yml
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=your-mailtrap-username
MAIL_PASSWORD=your-mailtrap-password
MAIL_FROM=noreply@grainpay.dev
